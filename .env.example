# ─────────────────────────────────────────────
# Lumière — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Edge Functions only — keep secret

# ── Stripe ────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_...    # Safe to expose in frontend JS
STRIPE_SECRET_KEY=sk_test_...         # Edge Functions only — keep secret
STRIPE_WEBHOOK_SECRET=whsec_...       # Generated when you create a webhook endpoint
